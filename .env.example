# ============================================================
# NexStock — variáveis de ambiente (EXEMPLO)
# ============================================================

# Perfil ativo: dev | prod
SPRING_PROFILES_ACTIVE=dev

# Porta do servidor
SERVER_PORT=8080

# ---------------------------------------------------------------
# Banco de dados
# ---------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seu_banco_dev
DB_USERNAME=seu_usuario
DB_PASSWORD=sua_senha

# Pool de conexões
DB_POOL_MAX=20
DB_POOL_MIN=5

# ---------------------------------------------------------------
# Logs
# ---------------------------------------------------------------
LOG_PATH=/caminho/para/logs

# ---------------------------------------------------------------
# JWT
# ---------------------------------------------------------------
JWT_SECRET=sua_chave_secreta_aqui
JWT_EXPIRACAO_MS=86400000

# ---------------------------------------------------------------
# AWS S3 / Upload de imagens
# ---------------------------------------------------------------
AWS_REGION=sa-east-1
AWS_S3_BUCKET=seu-bucket-de-imagens
AWS_S3_PRODUCT_IMAGES_PREFIX=produtos
AWS_S3_PUBLIC_BASE_URL=

# Use somente em desenvolvimento local ou CI controlado.
# Em producao, prefira IAM Role, ECS Task Role, EKS IRSA ou secrets do provedor.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

UPLOAD_MAX_FILE_SIZE=5MB
UPLOAD_MAX_REQUEST_SIZE=6MB
STORAGE_MAX_FILE_SIZE=5MB
